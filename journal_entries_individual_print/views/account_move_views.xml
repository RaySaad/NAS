<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Extend the Journal Entries list view to add
        "Print Separate PDFs" option inside the Print dropdown button.
    -->
    <record id="view_account_move_list_inherit_separate_pdf" model="ir.ui.view">
        <field name="name">account.move.list.inherit.separate.pdf</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">

            <!--
                Add a new item inside the existing "Print" button group.
                The Print button in Odoo 18 Journal Entries list view is rendered
                via the <header> action buttons area.
                We inject our new action as a binding action (server action).
            -->

            <!-- The server action binding (defined in wizard XML) automatically
                 appears in the "Actions" dropdown. We additionally surface it
                 inside the Print dropdown by adding a dedicated button here. -->
            <xpath expr="//list" position="attributes">
                <attribute name="string">Journal Entries</attribute>
            </xpath>

        </field>
    </record>

    <!--
        Add the wizard action to the Print dropdown by registering it
        as an ir.actions.act_window accessible from the top Print menu.

        In Odoo 18 the "Print" button in list views is populated via
        ir.actions.report records bound to the model. We register our
        wizard as an action that appears alongside the existing print options
        by using a client action triggered from the Action menu.

        The server action defined in print_separate_pdf_wizard_views.xml
        with binding_view_types="list" will already appear in the ⚙ Actions menu.

        To also appear inside the 🖨 Print dropdown we define a report-like
        action below using type=ir.actions.client.
    -->

    <!-- Register the wizard as a named action reachable from the Print dropdown -->
    <record id="action_print_separate_pdfs_from_print_menu" model="ir.actions.act_window">
        <field name="name">Print Individual Journal Entries</field>
        <field name="res_model">account.move.print.separate.pdf.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
    </record>

</odoo>
