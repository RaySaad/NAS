<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_org_chart.action_hr_employee_org_chart" model="ir.actions.act_window">
        <field name="view_mode">list,kanban,form,activity,graph,pivot,hierarchy</field>
    </record>
    
    <record model="ir.ui.view" id="employee_ext.view_employee_list">
        <field name="name">employee_ext.view.employee.list</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="arabic_name"/>
            </field>
        </field>
    </record>
    
    <record model="ir.ui.view" id="employee_ext.view_employee_form">
        <field name="name">employee_ext.view.employee.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_title')]" position="replace">
                <div class="oe_title mw-75 ps-0 pe-2">
                    <h1 class="d-flex">
                        <field name="name" placeholder="Employee's Name" required="True"/>
                    </h1>
                    <h1>
                        <field name="arabic_name" placeholder="الاسم باللغة العربية"/>
                    </h1>
                    <h2>
                        <field name="identification_id" placeholder="Indentification Number"/>
                    </h2>
                </div>
            </xpath>
            <field name="department_id" position="after">-->
                <field name="sponsor" required="1"/>
                <field name="sponsor_id" string="Sponsor ID"/>
            </field>
        </field>
    </record>
</odoo>
