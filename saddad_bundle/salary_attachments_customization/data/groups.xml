<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record model="ir.module.category" id="module_category_salary_attachment">
            <field name="name">Salary Attachments</field>
            <field name="description">Helps you manage your Salary Attachment Relevant Activities</field>
            <field name="sequence">3</field>
        </record>

        <!--Loan Approval Groups-->
        <record id="loan_approvers" model="res.groups">
            <field name="name">Loan Approvers</field>
            <field name="category_id" ref="module_category_salary_attachment"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>