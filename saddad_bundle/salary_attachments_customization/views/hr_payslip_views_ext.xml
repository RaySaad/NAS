<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_form_ext" model="ir.ui.view">
        <field name="name">hr.payslip.form.ext</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='input_line_ids']//field[@name='amount']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
            <xpath expr="//field[@name='input_line_ids']/list " position="attributes">
                <attribute name="delete">0</attribute>
            </xpath>
        </field>
    </record>
</odoo>