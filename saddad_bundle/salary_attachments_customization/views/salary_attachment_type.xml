<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_salary_attachment_view_type_form_ext" model="ir.ui.view">
        <field name="name">hr.salary.attachment.type.view.form</field>
        <field name="model">hr.payslip.input.type</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_input_type_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='country_id']" position="after">
                <field name="payment_type"/>
            </xpath>
            <xpath expr="//field[@name='code']" position="after">
                <field name="company_id"/>
<!--                <field name="employee_payment_type_id"/>-->
            </xpath>
        </field>
    </record>
</odoo>
