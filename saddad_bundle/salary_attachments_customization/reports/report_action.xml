<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="paperformat_loan_request_report" model="report.paperformat">
        <field name="name">Customized Paper Format</field>
        <field name="default" eval="True"/>
        <field name="format">custom</field>
        <field name="page_height">297</field>
        <field name="page_width">210</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="loan_request_report_action" model="ir.actions.report">
        <field name="name">Loan Request</field>
        <field name="model">hr.salary.attachment.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">salary_attachments_customization.letter_report</field>
        <field name="report_file">salary_attachments_customization.letter_report</field>
        <field name="binding_model_id" ref="model_hr_salary_attachment_request"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_loan_request_report"/>
    </record>

</odoo>
