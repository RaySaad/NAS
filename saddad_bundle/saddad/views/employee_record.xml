<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="employee_record_form_view" model="ir.ui.view">
        <field name="name">employee.record.form</field>
        <field name="model">employee.record</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_update_from_hr" type="object" string="Update from HR"
                            class="btn-primary" invisible="employee_type != 'internal' or not employee_id"
                            confirm="Are you sure you want to update this record with latest HR data?"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_type" widget='radio'/>
                            <field name="employee_id" invisible="employee_type != 'internal'"/>
                            <field name="employee_number" readonly="1" invisible="employee_type != 'internal'"
                                   force_save="1"/>
                            <field name="employee_name" required="1" readonly="employee_type == 'internal'"/>
                            <field name="identification_id" required="1" readonly="employee_type == 'internal'"/>
                        </group>
                        <group>
                            <label for="start_date"/>
                            <div>
                                <field name="start_date" class="block" placeholder="Iqama Issue Date"/>
                                <field name="start_date_hijri" class="block"
                                       placeholder="Hijri 'YYYY-MM-DD'" readonly="1" force_save="1"/>
                            </div>
                            <label for="identification_expiry_date"/>
                            <div>
                                <field name="identification_expiry_date" class="block" placeholder="Iqama Expiry Date"/>
                                <field name="identification_expiry_date_hijri" class="block"
                                       placeholder="Hijri 'YYYY-MM-DD'" readonly="1" force_save="1"/>
                            </div>
                            <field name="sponsor_id" readonly="employee_type == 'internal'"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="employee_record_tree_view" model="ir.ui.view">
        <field name="name">employee.record.tree</field>
        <field name="model">employee.record</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="action_bulk_update_from_hr" type="object" string="Bulk Update from HR" class="btn-primary"/>
                </header>
                <field name="identification_id"/>
                <field name="employee_name"/>
                <field name="employee_number"/>
                <field name="start_date"/>
                <field name="identification_expiry_date"/>
                <field name="company_id"/>
                <field name="employee_type" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="employee_record_search_view" model="ir.ui.view">
        <field name="name">employee.record.search</field>
        <field name="model">employee.record</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search>
                <field name="identification_id"/>
                <field name="employee_name"/>
            </search>
        </field>
    </record>

    <record id="action_pull_employees" model="ir.actions.server">
        <field name="name">Pull Employees</field>
        <field name="model_id" ref="model_employee_record"/>
        <field name="state">code</field>
        <field name="code">action = model.action_pull_employees()</field>
    </record>

    <record id="employee_record_action" model="ir.actions.act_window">
        <field name="name">Saddad Employees</field>
        <field name="res_model">employee.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="employee_record_menu" name="Saddad Employees" sequence="5"
              action="saddad.employee_record_action" parent="saddad.document_renewal_root"/>

    <menuitem id="pull_employees_menu" name="Pull Employees" sequence="6"
              action="saddad.action_pull_employees" parent="saddad.document_renewal_root"/>
</odoo>