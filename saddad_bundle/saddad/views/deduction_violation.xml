<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--Employee deductions - violations form view-->
    <record model="ir.ui.view" id="employee_deductions_violations_form_ext">
        <field name="name">employee.deductions.violations form ext</field>
        <field name="model">employee.deductions.violations</field>
        <field name="inherit_id" ref="hr_loans.employee_deductions_violations_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group[1]" position="before">
                <div class="oe_button_box" name="button_box">
                    <field name="morror_id" invisible="1"/>
                    <button name="action_open_morror" class="oe_stat_button"
                            icon="fa-file-text-o"
                            type="object">
                        Morror
                    </button>
                </div>
            </xpath>
        </field>
    </record>
</odoo>