<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_category_form_view_ext" model="ir.ui.view">
        <field name="name">product.category.ext</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='first']" position="after">
                <group name="expense_type" col="2">
                    <field name="type" class="oe_inline" string="Type"/>
                </group>
            </xpath>
        </field>
    </record>


    <!-- Category Mapping Menu Items-->
    <menuitem id="Product_category_mapping_menu" name="Category Mapping"
              action="product.product_category_action_form" parent="saddad.menu_document_renewal_configuration"/>


</odoo>
