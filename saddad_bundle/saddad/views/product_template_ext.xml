<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_only_form_view_extension" model="ir.ui.view">
        <field name="name">product.template</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="renewal_item"/>
                    <label for="renewal_item"/>
                </span>
                <div class="o_field_radio" invisible="not renewal_item">
                    <field name="renewal_type" widget="radio" groups="base.group_no_one"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>