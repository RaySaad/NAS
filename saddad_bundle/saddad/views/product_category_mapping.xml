<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Product Category Mapping form view-->
    <record id="product_category_mapping_form_view" model="ir.ui.view">
        <field name="name">product_category_mapping</field>
        <field name="model">product.category.mapping</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form class="product_category_mapping" string="Product Category Mapping">
                <header>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="morror_category_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                </list>
                            </field>
                        </group>
                        <group>

                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!--Product Category Mapping tree view-->
    <record id="product_category_mapping_tree_view" model="ir.ui.view">
        <field name="name">product_category_mapping_tree_view</field>
        <field name="model">product.category.mapping</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Product Category Mapping">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!--Product Category Mapping action-->
    <record id="product_category_mapping_action" model="ir.actions.act_window">
        <field name="name">Category Mapping</field>
        <field name="res_model">product.category.mapping</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new record of product category mapping
            </p>
        </field>
    </record>


    <!-- Product Category Mapping Menu Items-->
    <menuitem id="Product_category_mapping_menu_item"
              action="saddad.product_category_mapping_action" parent="saddad.menu_document_renewal_configuration"/>


</odoo>