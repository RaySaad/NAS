<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--BIllers form view-->
    <record id="billers_form_view" model="ir.ui.view">
        <field name="name">billers.form.view</field>
        <field name="model">billers</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form class="billers" string="Billers">
                <sheet>
                    <group>
                        <group>
                            <field name="name" translate="True"/>

                        </group>
                        <group>
                            <field name="code"/>
                            <field name="partner_id" options="{'no_create':true,'no_open':true}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--BIllers tree view-->
    <record id="billers_tree_view" model="ir.ui.view">
        <field name="name">billers.tree.view</field>
        <field name="model">billers</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Billers">
                <field name="name"/>

                <field name="code"/>
                <field name="partner_id"/>
            </list>
        </field>
    </record>

    <!--BIllers action -->

    <record id="billers_action" model="ir.actions.act_window">
        <field name="name">Billers</field>
        <field name="res_model">billers</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Biller Record
            </p>
        </field>
    </record>

    <!-- Billers Menu Items-->
    <menuitem id="menu_billers_list" name="Biller List"
              action="saddad.billers_action" parent="saddad.menu_document_renewal_configuration"/>


</odoo>
