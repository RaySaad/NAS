<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Default Employee loan account form view-->
    <record id="company_loan_account_mapping_form_view" model="ir.ui.view">
        <field name="name">company.loan.account.mapping.form.view</field>
        <field name="model">company.loan.account.mapping</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form class="employee_loan_account" string="Employee Loan Account">
                <sheet>
                    <group>
                        <group>
                            <field name="loan_account_id" required="1" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="company_id" required="1" options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--Default Employee loan account tree view-->
    <record id="company_loan_account_mapping_tree_view" model="ir.ui.view">
        <field name="name">company.loan.account.mapping.tree.view</field>
        <field name="model">company.loan.account.mapping</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Default Employee Loan Account">
                <field name="loan_account_id"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <!--default employee loan account action -->

    <record id="default_employee_loan_account_action" model="ir.actions.act_window">
        <field name="name">Company's Default Employee Loan Account</field>
        <field name="res_model">company.loan.account.mapping</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Company's Default Employee Loan Account
            </p>
        </field>
    </record>

    <!-- default employee loan account Menu Items-->
    <menuitem id="default_employee_loan_account_menu" name="Company's Default Loan Account"
              action="saddad.default_employee_loan_account_action" parent="saddad.menu_document_renewal_configuration"/>


</odoo>
