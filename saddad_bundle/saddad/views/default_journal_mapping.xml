<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Default Bank Journal form view-->
    <record id="default_journal_mapping_form_view" model="ir.ui.view">
        <field name="name">default.journal.mapping.form.view</field>
        <field name="model">default.journal.mapping</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form class="billers" string="Billers">
                <sheet>
                    <group>
                        <group>
                            <field name="bank_journal_id" required="1" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="company_id" required="1" options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--Default Bank Journal tree view-->
    <record id="default_journal_mapping_tree_view" model="ir.ui.view">
        <field name="name">default.journal.mapping.tree.view</field>
        <field name="model">default.journal.mapping</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Default Bank">
                <field name="bank_journal_id"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <!--default journal action -->

    <record id="default_journal_action" model="ir.actions.act_window">
        <field name="name">Company's Default Bank</field>
        <field name="res_model">default.journal.mapping</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Company's Default Bank
            </p>
        </field>
    </record>

    <!-- default bank journal Menu Items-->
    <menuitem id="default_journal_menu" name="Company's Default Bank Journal"
              action="saddad.default_journal_action" parent="saddad.menu_document_renewal_configuration"/>


</odoo>
