<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Morror form view-->
    <record id="morror_form_view" model="ir.ui.view">
        <field name="name">morror_from_view</field>
        <field name="model">morror</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <widget id="attach_document" name="attach_document" string="Attach Receipt" class="oe_highlight"
                            type="object" invisible="not id"/>
                    <button name="action_confirm" type="object" string="Submit" invisible="state != 'draft' or not id"
                            class="oe_highlight"
                            groups="saddad.morror_user,saddad.fleet_manager_group,saddad.group_saddad_gm,saddad.group_saddad_administrator"/>
                    <button name="fleet_manager_approval" type="object" string="Fleet Manager"
                            invisible="state != 'fleet'"
                            groups="saddad.fleet_manager_group,saddad.group_saddad_gm,saddad.group_saddad_administrator"
                            class="oe_highlight"/>
                    <button name="financial_approval" type="object" string="Financial Approval"
                            groups="saddad.group_saddad_administrator, saddad.group_saddad_financial_approval"
                            invisible="state !='financial_approval'" class="oe_highlight"/>
                    <button name="gm_approval" type="object" string="Approve" invisible="state != 'gm'"
                            groups="saddad.group_saddad_gm,saddad.group_saddad_administrator"
                            class="oe_highlight"/>
                    <button name="post_entries" type="object" string="Post Entries" invisible="state != 'done'"
                            groups="saddad.saddad_post_entries,saddad.group_saddad_administrator" class="oe_highlight"/>
                    <button name="action_cancel" type="object" string="Cancel" class="oe_highlight"
                            groups="saddad.fleet_manager_group,saddad.group_saddad_gm,saddad.group_saddad_administrator"
                            invisible="state in ('draft','cancel','refused')"/>
                    <button name="action_refuse" type="object" string="Refuse" class="oe_highlight"
                            groups="saddad.fleet_manager_group,saddad.group_saddad_gm,saddad.group_saddad_administrator"
                            invisible="state not in ('fleet','gm','financial_approval','payment_pending')"/>

                    <button name="action_reset_to_draft" type="object" string="Reset To Draft"
                            groups="saddad.group_saddad_administrator"
                            invisible="state not in ('cancel', 'refused')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,refused,done,posted,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="account_move_id" invisible="1"/>
                        <button name="action_open_account_move" class="oe_stat_button" icon="fa-file-text-o"
                                type="object" invisible="account_move_id == False">
                            Journal Entry
                        </button>
                        <button name="action_get_attachment_view" string="View Documents" type="object"
                                icon="fa-paperclip" invisible="attachment_number == 0"/>
                    </div>
                    <group>
                        <group>
                            <field name="expense_type" readonly="state in ('done','payment_pending','posted')"/>
                            <field name="employee_id" options="{'no_create':true,'no_open':true}"
                                   invisible="expense_type not in ('traffic_violation','driving_licence')"
                                   required="expense_type in ('driving_licence','traffic_violation')"
                                   readonly="state != 'draft'"/>

                            <field name="identification_id" force_save="1" readonly="1"/>
                            <field name="deduction_date"
                                   readonly="state != 'draft'"
                                   invisible="expense_type != 'traffic_violation'"
                                   required="expense_type == 'traffic_violation'"/>
                            <!--                            <field name="sponsor_id" force_save="1" readonly="1"/>-->
                            <field name="bank_journal_id"
                                   readonly="state not in ('payment_pending')"
                                   options="{'no_create':true,'no_open':true}"/>
                            <field name="operating_unit_id" readonly="1"/>

                        </group>
                        <group>
                            <field name="company_id" readonly="1" options="{'no_create':true,'no_open':true}"/>
                            <field name="fleet_readonly" invisible="1"/>
                            <field name="fleet_id" options="{'no_create':true,'no_open':true}"
                                   readonly="state != 'draft' or fleet_readonly"/>
                            <field name="vehicle_no" string="License Plate" invisible="1"/>
                            <field name="owner_id" force_save="1" readonly="1"/>
                            <field name="sequence" force_save="1" readonly="1"/>
                            <field name="attachment_number" invisible="1"/>
                            <field name="is_gm_user" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Expenses" name="morror_line_ids">
                            <field name="morror_line_ids" context="{'default_expense_type': expense_type}"
                                   readonly="state != 'draft' and not is_gm_user">
                                <list decoration-success="is_paid" editable="bottom">
                                    <field name="date"/>
                                    <field name="is_paid" column_invisible="1"/>
                                    <field name="product_id" options="{'no_create': True}"/>
                                    <field name="description"/>
                                    <field name="analytic_account_id"/>
                                    <field name="unit_price" force_save="1"/>
                                    <field name="total_amount" force_save="1" optional="hide"/>
                                    <field name="violation_number"
                                           column_invisible="parent.expense_type != 'traffic_violation'"
                                           required="parent.expense_type == 'traffic_violation'"/>
                                    <field name="period"
                                           column_invisible="parent.expense_type != 'driving_licence'"
                                           required="parent.expense_type != 'traffic_violation'"/>
                                    <field name="violation_date"
                                           column_invisible="parent.expense_type != 'traffic_violation'"
                                           required="parent.expense_type == 'traffic_violation'"/>
                                    <field name="payment_mode"
                                           readonly="parent.state not in ('draft','fleet','gm')"/>
                                    <field name="note"/>
                                    <button name="service_paid" type="object"
                                            string="Paid"
                                            groups="saddad.group_saddad_administrator,saddad.group_saddad_accountant"
                                            invisible="is_paid or parent.state != 'payment_pending'"
                                            class="oe_highlight"/>
                                </list>
                            </field>
                            <group name="note_group" col="6" class="mt-2 mt-md-0">
                                <group colspan="4"/>
                                <group class="oe_subtotal_footer oe_right" colspan="1" name="total_amount">
                                    <field name="currency_id" invisible="1"/>
                                    <div class="o_td_label"></div>
                                    <field name="total_amount" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </group>
                                <div class="oe_clear"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!--Morror tree view-->
    <record id="morror_tree_view" model="ir.ui.view">
        <field name="name">morror_tree_view</field>
        <field name="model">morror</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'draft'"
                  decoration-info="state not in ('draft','done','posted','cancel')"
                  decoration-success="state in ('posted','done')">
                <field name="serial_number"/>
                <field name="date" widget="badge" decoration-info="1"/>
                <field name="product_id"/>
                <field name="employee_id"/>
                <field name="violation_number" invisible="1"/>

                <field name="fleet_id"/>
                <field name="expense_type"/>
                <field name="total_amount"/>
                <field name="attachment_number" invisible="1"/>
                <button name="action_get_attachment_view" string="View Documents" type="object"
                        icon="fa-paperclip" invisible="attachment_number == 0"/>
                <field name="state" widget="badge" decoration-danger="state == 'draft'"
                       decoration-info="state not in ('draft','done','posted','cancel')"
                       decoration-success="state in ('posted','done')"/>
            </list>
        </field>
    </record>

    <!--Morror Search View-->
    <record id="morror_search_view" model="ir.ui.view">
        <field name="name">morror_search_view</field>
        <field name="model">morror</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search>
                <filter name="draft" string="Draft" domain="[('state', '=', parent.state)]"/>
                <filter name="fleet" string="Fleet Manager" domain="[('state', '=', 'fleet')]"/>
                <filter name="gm" string="GM" domain="[('state', '=', 'gm')]"/>
                <filter name="payment" string="Payment" domain="[('state', '=', 'payment_pending')]"/>
                <filter name="done" string="Done" domain="[('state', '=', 'done')]"/>
                <filter name="posted" string="Posted" domain="[('state', '=', 'posted')]"/>
                <filter name="cancel" string="Canceled" domain="[('state', '=', 'cancel')]"/>
                <field name="expense_type"/>
                <field name="product_id"/>
                <field name="fleet_id"/>
                <field name="employee_id"/>
                <field name="identification_id"/>
                <field name="violation_number"/>
            </search>
        </field>
    </record>

    <!--Morror action-->
    <record id="morror_action" model="ir.actions.act_window">
        <field name="name">Morror</field>
        <field name="res_model">morror</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new morror record
            </p>
        </field>
    </record>

    <!-- Morror sequence-->
    <record id="ir_sequence_morror" model="ir.sequence">
        <field name="name">Morror</field>
        <field name="code">morror</field>
        <field name="prefix">Morror/%(year)s/</field>
        <field name="padding">2</field>
        <field name="company_id" eval="False"/>
    </record>

    <!--Morror Menu Items-->
    <menuitem id="morror_menu" name="Morror" sequence="3"
              groups="base.group_system,saddad.morror_user,saddad.group_saddad_administrator,saddad.saddad_post_entries,saddad.group_saddad_accountant,saddad.group_saddad_gm,saddad.fleet_manager_group,saddad.group_saddad_financial_approval"
              action="saddad.morror_action" parent="saddad.document_renewal_root"/>

</odoo>