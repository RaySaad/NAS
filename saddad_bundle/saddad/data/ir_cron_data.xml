<odoo>
    <data>


        <record id="check_document_expiry" model="ir.cron">
            <field name="name">Check Documents Expiry</field>
            <field name="model_id" ref="model_document_renewal"/>
            <field name="state">code</field>
            <field name="code">model.check_document_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>


        <record id="delete_renewal_requests" model="ir.cron">
            <field name="name">Delete Renewal Request</field>
            <field name="model_id" ref="model_document_renewal"/>
            <field name="state">code</field>
            <field name="code">model.delete_renewal_request()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>

    </data>
</odoo>