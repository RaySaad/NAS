            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="groups_id" eval="[(4, ref('saddad.group_saddad_hr_assistant'))]"/>
            <field name="code">
                if records:
                action = records.hr_assistant_approve()
            </field>
        </record>

