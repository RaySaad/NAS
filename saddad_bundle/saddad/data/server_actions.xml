<odoo>
    <data>

        <record id="action_validate_muqeem_expense" model="ir.actions.server">
            <field name="name">Validate Expense</field>
            <field name="model_id" ref="saddad.model_document_renew_expense"/>
            <field name="binding_model_id" ref="saddad.model_document_renew_expense"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                if records:
                action = records.action_validate_expense()
            </field>
        </record>

