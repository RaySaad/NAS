            <field name="name">Saddad Financial</field>
            <field name="category_id" ref="module_category_saddad"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>


        <record id="group_saddad_gm" model="res.groups">
            <field name="name">Saddad GM</field>
