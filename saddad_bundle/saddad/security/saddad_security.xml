            <field name="name">Saddad Payment</field>
            <field name="category_id" ref="module_category_saddad"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user')),(4, ref('hr_payroll.group_hr_payroll_user'))]"/>
        </record>

        <record id="document_renewal_multi_company" model="ir.rule">
            <field name="name">Pending to Renew: Multi Company</field>
            <field name="model_id" ref="model_document_renewal"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="employee_record_multi_company" model="ir.rule">
