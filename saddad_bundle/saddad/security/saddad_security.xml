<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record model="ir.module.category" id="module_category_saddad">
            <field name="name">Saddad</field>
            <field name="description">Helps you manage your Saddad Relevant Activities</field>
            <field name="sequence">3</field>
        </record>

        <!--Saddad Groups-->
        <record id="group_saddad_administrator" model="res.groups">
            <field name="name">Saddad Administrator</field>
            <field name="category_id" ref="module_category_saddad"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_saddad_hr_assistant" model="res.groups">
            <field name="name">Saddad HR Assistant</field>
            <field name="category_id" ref="module_category_saddad"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_saddad_pending_to_renew" model="res.groups">
            <field name="name">Saddad Pending To Renew</field>
            <field name="category_id" ref="module_category_saddad"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_saddad_hr" model="res.groups">
            <field name="name">Saddad HR</field>
