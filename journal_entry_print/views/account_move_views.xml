<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Print button to Journal Entry Form -->
    <record id="view_move_form_inherit_print" model="ir.ui.view">
        <field name="name">account.move.form.inherit.print</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <xpath expr="//form//header" position="inside">
                <button name="%(action_report_journal_entry)d" 
                        string="Print Voucher" 
                        type="action" 
                        class="btn-secondary"
                        icon="fa-print"/>
            </xpath>
        </field>
    </record>
</odoo>
